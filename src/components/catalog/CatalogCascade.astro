---
import type { FeaturedWatch } from '../../types/homepage';

interface Props {
  watches: FeaturedWatch[];
}

const { watches } = Astro.props;
---

<ul class="catalog-cascade" role="list" aria-label="Catálogo de relojes">
  {watches.map((watch, i) => {
    return (
      <li
        class="cascade-item"
        data-category={watch.mood ?? 'all'}
      >
        <a
          href={`/watches/${watch.id}`}
          class="cascade-item__link"
          aria-label={`Ver detalle de ${watch.name}`}
        >
          <div class="cascade-item__image-wrap">
            {watch.image ? (
              <>
                {/* Primary image */}
                <img
                  src={watch.image.src}
                  alt={watch.image.alt}
                  class="cascade-item__image cascade-item__image--primary"
                  loading={i < 3 ? 'eager' : 'lazy'}
                  transition:name={`watch-img-${watch.id}`}
                />
                {/* Hover image — only rendered if hoverImage is defined */}
                {watch.hoverImage && (
                  <img
                    src={watch.hoverImage.src}
                    alt={watch.hoverImage.alt}
                    class="cascade-item__image cascade-item__image--hover"
                    loading="lazy"
                    aria-hidden="true"
                  />
                )}
              </>
            ) : (
              <div class="cascade-item__image-placeholder" aria-hidden="true" />
            )}
          </div>

          <div class="cascade-item__info">
            <div class="cascade-item__meta">
              <h2 class="cascade-item__name">{watch.name}</h2>
              <span class="cascade-item__price">Consultar</span>
            </div>
            <p class="cascade-item__collection">{watch.collection}</p>
          </div>
        </a>
      </li>
    );
  })}
</ul>

<style is:global>
  .catalog-cascade {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    align-items: start;
  }

  .cascade-item {
    transition: transform var(--transition-precision), opacity var(--transition-precision);
  }

  .cascade-item__link {
    display: block;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface);
    color: inherit;
    text-decoration: none;
    transition:
      transform 300ms ease,
      box-shadow 300ms ease;
  }

  .cascade-item__link:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 60px rgb(var(--color-shadow-rgb) / 0.7);
  }

  /* Image container with universal golden gradient background */
  .cascade-item__image-wrap {
    position: relative;
    aspect-ratio: 3 / 3.5;
    overflow: hidden;
    background: 
      linear-gradient(
        to top left,
        rgb(160 130 65 / 0.32) 0%,
        rgb(115 90 45 / 0.12) 35%,
        transparent 60%
      ),
      var(--color-surface);
    transition: background var(--transition-precision);
  }

  /* Both images share the same slot */
  .cascade-item__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    padding: var(--space-16);
  }

  /* Primary: always visible, scales subtly on hover */
  .cascade-item__image--primary {
    opacity: 1;
    transition:
      opacity 500ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 500ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .cascade-item__link:hover .cascade-item__image--primary {
    opacity: 0;
    transform: scale(1.04);
  }

  /* Hover image: hidden by default, crossfades in */
  .cascade-item__image--hover {
    opacity: 0;
    transform: scale(0.97);
    transition:
      opacity 500ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 500ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .cascade-item__link:hover .cascade-item__image--hover {
    opacity: 1;
    transform: scale(1);
  }

  .cascade-item__image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(
      135deg,
      var(--color-surface-variant) 0%,
      var(--color-surface) 100%
    );
  }

  /* Info row below image */
  .cascade-item__info {
    padding: var(--space-16) var(--space-16) var(--space-24);
    border-top: 1px solid rgb(var(--color-outline-variant-rgb) / 0.1);
  }

  .cascade-item__meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-8);
    margin-bottom: var(--space-4);
  }

  .cascade-item__name {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    font-weight: 500;
    color: var(--color-on-surface);
    line-height: 1.2;
  }

  .cascade-item__price {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .cascade-item__collection {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--color-on-surface-variant);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  /* Responsive: 2 cols tablet */
  @media (max-width: 900px) {
    .catalog-cascade {
      grid-template-columns: repeat(2, 1fr);
    }


  }

  /* Responsive: 1 col mobile */
  @media (max-width: 560px) {
    .catalog-cascade {
      grid-template-columns: 1fr;
      gap: var(--space-16);
    }


  }
</style>
