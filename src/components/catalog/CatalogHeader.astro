---
const navItems = [
  { href: '/', label: 'Inicio', isActive: false },
  { href: '/catalogo', label: 'Catálogo', isActive: true },
];

const filters = [
  { id: 'all', label: 'Todos', isActive: true },
  { id: 'sport', label: 'Deportivos' },
  { id: 'dress', label: 'Vestir' },
  { id: 'limited', label: 'Edición Limitada' },
];
---

<header class="catalog-header">
  <div class="catalog-header__inner">
    <a class="catalog-header__brand" href="/" aria-label="AVC TIME — Inicio">
      AVC Time
    </a>

    <nav class="catalog-header__nav" aria-label="Navegación principal">
      {navItems.map((item) => (
        <a
          class:list={['catalog-header__link', item.isActive && 'is-active']}
          href={item.href}
          aria-current={item.isActive ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="catalog-header__actions">
      <div class="catalog-filters" role="group" aria-label="Filtrar por categoría">
        <button class="filter-pill is-active" data-filter="all">Todos</button>
        <button class="filter-pill" data-filter="gold">Complicaciones</button>
        <button class="filter-pill" data-filter="smoke">Deportivos</button>
      </div>

      <div class="catalog-header__divider" aria-hidden="true" style="width: 1px; height: 24px; background: rgb(var(--color-outline-variant-rgb) / 0.25); margin-inline: 4px;"></div>

      <a class="catalog-header__icon" href="/catalogo" aria-label="Ver catálogo">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M7.25 8.25h9.5l-.72 9.5a2 2 0 0 1-2 1.85H9.97a2 2 0 0 1-2-1.85l-.72-9.5Z" />
          <path d="M9 8.25V7a3 3 0 0 1 6 0v1.25" />
        </svg>
      </a>
      <a class="catalog-header__profile" href="/" aria-label="Perfil AVC TIME">
        <span aria-hidden="true">AVC</span>
      </a>
    </div>
  </div>
</header>


