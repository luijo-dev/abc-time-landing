---
/**
 * WatchDetailDrawer
 *
 * A full-viewport overlay that slides in when the user clicks a watch card
 * in the catalog. All watch data is embedded as JSON in data-attributes and
 * rendered dynamically by the client script so we keep a single Astro
 * component without per-watch pages.
 *
 * Triggered by: custom event `watch:open` dispatched by CatalogCascade.
 */
---

<!-- Overlay backdrop -->
<div id="watch-drawer-backdrop" class="drawer-backdrop" aria-hidden="true"></div>

<!-- Drawer panel -->
<aside
  id="watch-drawer"
  class="watch-drawer"
  role="dialog"
  aria-modal="true"
  aria-labelledby="drawer-watch-name"
  tabindex="-1"
>
  <!-- Close button -->
  <button id="drawer-close" class="drawer-close" aria-label="Cerrar detalle">
    <span class="drawer-close__icon" aria-hidden="true">✕</span>
  </button>

  <!-- Scrollable content -->
  <div class="drawer-scroll">

    <!-- ── 1. Hero ── -->
    <section class="drawer-hero">
      <div class="drawer-hero__content">
        <p id="drawer-eyebrow" class="drawer-eyebrow"></p>
        <h2 id="drawer-watch-name" class="drawer-title"></h2>
        <p id="drawer-collection" class="drawer-collection"></p>
        <p id="drawer-description" class="drawer-description"></p>

        <div class="drawer-cta-row">
          <a id="drawer-cta-whatsapp" href="#" target="_blank" rel="noopener noreferrer" class="btn-primary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.108.549 4.088 1.512 5.806L.057 23.535a.75.75 0 0 0 .908.908l5.727-1.454A11.94 11.94 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.891 0-3.667-.496-5.201-1.364l-.373-.214-3.861.98.998-3.861-.222-.385A9.957 9.957 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
            Consultar por WhatsApp
          </a>
          <button class="btn-secondary">Solicitar Visita</button>
        </div>
      </div>

      <div class="drawer-hero__image-wrap">
        <div class="drawer-hero__image-glow" aria-hidden="true"></div>
        <img id="drawer-watch-image" src="" alt="" class="drawer-hero__image" />
      </div>
    </section>

    <!-- ── 2. Technical Specs ── -->
    <section class="drawer-specs-section">
      <div class="drawer-specs-header">
        <h3 class="drawer-specs-title">Especificaciones Técnicas</h3>
        <div class="drawer-specs-rule" aria-hidden="true"></div>
      </div>
      <div id="drawer-specs-grid" class="drawer-specs-grid"></div>
    </section>

    <!-- ── 3. Ergonomics ── -->
    <section class="drawer-ergo" id="drawer-ergo">
      <div class="drawer-ergo__image-wrap">
        <img id="drawer-ergo-image" src="" alt="Reloj en muñeca" class="drawer-ergo__image" />
        <div class="drawer-ergo__overlay" aria-hidden="true"></div>
      </div>
      <div class="drawer-ergo__content">
        <p class="drawer-ergo__eyebrow">HOW IT LOOKS ON</p>
        <h3 id="drawer-ergo-title" class="drawer-ergo__title"></h3>
        <div id="drawer-ergo-body" class="drawer-ergo__body"></div>
        <a href="#" class="drawer-ergo__link">
          <span class="drawer-ergo__link-line" aria-hidden="true"></span>
          Explora la ergonomía
        </a>
      </div>
    </section>

  </div><!-- /drawer-scroll -->
</aside>

<script>
  // ── Types (runtime, no TS needed) ──────────────────────────────────────

  const backdrop  = document.getElementById('watch-drawer-backdrop')!;
  const drawer    = document.getElementById('watch-drawer')!;
  const closeBtn  = document.getElementById('drawer-close')!;

  // Elements inside the drawer
  const elEyebrow     = document.getElementById('drawer-eyebrow')!;
  const elName        = document.getElementById('drawer-watch-name')!;
  const elCollection  = document.getElementById('drawer-collection')!;
  const elDesc        = document.getElementById('drawer-description')!;
  const elCtaWA       = document.getElementById('drawer-cta-whatsapp') as HTMLAnchorElement;
  const elImage       = document.getElementById('drawer-watch-image') as HTMLImageElement;
  const elSpecsGrid   = document.getElementById('drawer-specs-grid')!;
  const elErgo        = document.getElementById('drawer-ergo')!;
  const elErgoImage   = document.getElementById('drawer-ergo-image') as HTMLImageElement;
  const elErgoTitle   = document.getElementById('drawer-ergo-title')!;
  const elErgoBody    = document.getElementById('drawer-ergo-body')!;

  // ── Open / Close ────────────────────────────────────────────────────────

  function openDrawer(watchData: any) {
    populateDrawer(watchData);
    drawer.classList.add('is-open');
    backdrop.classList.add('is-visible');
    document.body.style.overflow = 'hidden';
    drawer.focus();
  }

  function closeDrawer() {
    drawer.classList.remove('is-open');
    backdrop.classList.remove('is-visible');
    document.body.style.overflow = '';
  }

  // ── Populate ─────────────────────────────────────────────────────────────

  function populateDrawer(w: any) {
    const detail = w.detail ?? {};

    elEyebrow.textContent   = detail.eyebrow ?? w.collection;
    elName.textContent      = w.name;
    elCollection.textContent = w.collection;
    elDesc.textContent      = detail.description ?? '';
    elCtaWA.href            = w.ctaUrl ?? '#';

    if (w.image) {
      elImage.src = w.image.src;
      elImage.alt = w.image.alt ?? w.name;
    }

    // Specs grid
    elSpecsGrid.innerHTML = '';
    const groups: any[] = detail.specGroups ?? [];
    groups.forEach((group: any) => {
      const card = document.createElement('div');
      card.className = 'spec-card';

      const rows = (group.rows ?? []).map((r: any) => `
        <li class="spec-row">
          <span class="spec-row__label">${r.label}</span>
          <span class="spec-row__value">${r.value}</span>
        </li>`).join('');

      card.innerHTML = `
        <span class="material-symbols-outlined spec-card__icon">${group.icon}</span>
        <h4 class="spec-card__title">${group.title}</h4>
        <ul class="spec-card__rows">${rows}</ul>
      `;
      elSpecsGrid.appendChild(card);
    });

    // Ergonomics section
    const ergo = detail.ergonomics;
    if (ergo) {
      elErgo.style.display = '';
      elErgoTitle.textContent = ergo.title ?? '';
      elErgoBody.innerHTML = (ergo.body ?? []).map((p: string) => `<p>${p}</p>`).join('');
      if (ergo.image) {
        elErgoImage.src = ergo.image.src;
        elErgoImage.alt = ergo.image.alt ?? '';
        elErgoImage.style.display = '';
      } else {
        elErgoImage.style.display = 'none';
      }
    } else {
      elErgo.style.display = 'none';
    }

    // Reset scroll to top
    drawer.querySelector('.drawer-scroll')!.scrollTop = 0;
  }

  // ── Event Listeners ─────────────────────────────────────────────────────

  document.addEventListener('watch:open', (e: Event) => {
    openDrawer((e as CustomEvent).detail);
  });

  closeBtn.addEventListener('click', closeDrawer);
  backdrop.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer.classList.contains('is-open')) closeDrawer();
  });
</script>

<style>
  /* ── Material Symbols font (re-import inside shadow component) ─────── */
  @import url('https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@400,0&display=swap');

  /* ── Backdrop ──────────────────────────────────────────────────────── */
  .drawer-backdrop {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgb(0 0 0 / 0.7);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 400ms ease;
  }
  .drawer-backdrop.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Drawer Panel ───────────────────────────────────────────────────── */
  .watch-drawer {
    position: fixed;
    inset-block: 0;
    inset-inline-end: 0;
    z-index: 210;
    width: min(900px, 100vw);
    background: #0e0c09;
    box-shadow: -40px 0 120px rgb(0 0 0 / 0.8);
    transform: translateX(100%);
    transition: transform 480ms cubic-bezier(0.23, 1, 0.32, 1);
    outline: none;
    display: flex;
    flex-direction: column;
  }
  .watch-drawer.is-open {
    transform: translateX(0);
  }

  /* ── Close button ───────────────────────────────────────────────────── */
  .drawer-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    z-index: 10;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: 1px solid rgb(255 255 255 / 0.12);
    background: rgb(255 255 255 / 0.06);
    color: var(--color-on-surface, #e5e2e1);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 200ms ease, border-color 200ms ease;
  }
  .drawer-close:hover {
    background: rgb(255 255 255 / 0.14);
    border-color: var(--color-primary, #f2ca50);
    color: var(--color-primary, #f2ca50);
  }
  .drawer-close__icon { font-size: 1rem; line-height: 1; }

  /* ── Scrollable area ────────────────────────────────────────────────── */
  .drawer-scroll {
    flex: 1;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: #353534 transparent;
  }
  .drawer-scroll::-webkit-scrollbar { width: 6px; }
  .drawer-scroll::-webkit-scrollbar-thumb { background: #353534; border-radius: 3px; }

  /* ══════════════════════════════════════════════════
     SECTION 1 — HERO
  ══════════════════════════════════════════════════ */
  .drawer-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 480px;
    padding: 5rem 3rem 3rem;
    gap: 2rem;
    align-items: center;
    border-bottom: 1px solid rgb(255 255 255 / 0.06);
    position: relative;
  }

  .drawer-hero__content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .drawer-eyebrow {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant, #a3a3a3);
    margin: 0;
  }

  .drawer-title {
    font-family: var(--font-display, 'Noto Serif', serif);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.05;
    color: var(--color-on-surface, #e5e2e1);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .drawer-title .highlight {
    color: var(--color-primary, #f2ca50);
  }

  .drawer-collection {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant, #a3a3a3);
    margin: -0.5rem 0 0;
  }

  .drawer-description {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgb(229 226 225 / 0.75);
    max-width: 36ch;
    margin: 0;
  }

  /* CTA buttons */
  .drawer-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    background: var(--color-primary, #f2ca50);
    color: #241a00;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    border-radius: 2px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 200ms ease, box-shadow 200ms ease;
    box-shadow: 0 0 24px rgb(242 202 80 / 0.25);
  }
  .btn-primary:hover {
    background: #e9c349;
    box-shadow: 0 0 32px rgb(242 202 80 / 0.4);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.5rem;
    background: transparent;
    color: var(--color-on-surface, #e5e2e1);
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    border-radius: 2px;
    border: 1px solid rgb(255 255 255 / 0.15);
    cursor: pointer;
    transition: border-color 200ms ease, background 200ms ease;
  }
  .btn-secondary:hover {
    border-color: rgb(255 255 255 / 0.35);
    background: rgb(255 255 255 / 0.04);
  }

  /* Hero image */
  .drawer-hero__image-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .drawer-hero__image-glow {
    position: absolute;
    inset: 10%;
    border-radius: 50%;
    background: radial-gradient(circle, rgb(212 175 55 / 0.15) 0%, transparent 70%);
    pointer-events: none;
  }
  .drawer-hero__image {
    width: 100%;
    max-width: 380px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 30px 60px rgb(0 0 0 / 0.7));
    transition: transform 400ms ease;
  }
  .watch-drawer.is-open .drawer-hero__image {
    transform: translateY(-4px);
  }

  /* ══════════════════════════════════════════════════
     SECTION 2 — TECHNICAL SPECS
  ══════════════════════════════════════════════════ */
  .drawer-specs-section {
    padding: 3rem;
    border-bottom: 1px solid rgb(255 255 255 / 0.06);
  }

  .drawer-specs-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .drawer-specs-title {
    font-family: var(--font-display, 'Noto Serif', serif);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-on-surface, #e5e2e1);
    white-space: nowrap;
    margin: 0;
  }

  .drawer-specs-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--color-primary, #f2ca50), transparent);
  }

  .drawer-specs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgb(255 255 255 / 0.06);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-radius: 4px;
    overflow: hidden;
  }

  .spec-card {
    background: rgb(255 255 255 / 0.02);
    padding: 1.5rem;
    transition: background 200ms ease;
  }
  .spec-card:hover { background: rgb(255 255 255 / 0.05); }

  .spec-card__icon {
    font-family: 'Material Symbols Outlined', sans-serif;
    font-size: 1.5rem;
    color: var(--color-primary, #f2ca50);
    display: block;
    margin-bottom: 0.75rem;
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
  }

  .spec-card__title {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-on-surface, #e5e2e1);
    margin: 0 0 1rem;
    letter-spacing: 0.02em;
  }

  .spec-card__rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .spec-row {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgb(255 255 255 / 0.06);
  }
  .spec-row:last-child { border-bottom: none; padding-bottom: 0; }

  .spec-row__label {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant, #a3a3a3);
  }

  .spec-row__value {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-on-surface, #e5e2e1);
  }

  /* ══════════════════════════════════════════════════
     SECTION 3 — ERGONOMICS
  ══════════════════════════════════════════════════ */
  .drawer-ergo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 480px;
  }

  .drawer-ergo__image-wrap {
    position: relative;
    overflow: hidden;
  }
  .drawer-ergo__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: grayscale(0.4);
  }
  .drawer-ergo__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 60%, #0e0c09);
  }

  .drawer-ergo__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 3rem;
    gap: 1.25rem;
  }

  .drawer-ergo__eyebrow {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-primary, #f2ca50);
    margin: 0;
  }

  .drawer-ergo__title {
    font-family: var(--font-display, 'Noto Serif', serif);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-on-surface, #e5e2e1);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .drawer-ergo__body {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .drawer-ergo__body p {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.88rem;
    line-height: 1.75;
    color: rgb(229 226 225 / 0.65);
    margin: 0;
  }

  .drawer-ergo__link {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.5rem;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-on-surface, #e5e2e1);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 200ms ease;
  }
  .drawer-ergo__link:hover { color: var(--color-primary, #f2ca50); }
  .drawer-ergo__link-line {
    display: inline-block;
    width: 2.5rem;
    height: 1px;
    background: var(--color-primary, #f2ca50);
    flex-shrink: 0;
    transition: width 200ms ease;
  }
  .drawer-ergo__link:hover .drawer-ergo__link-line { width: 3.5rem; }

  /* ── Responsive ──────────────────────────────────────────────────────── */
  @media (max-width: 700px) {
    .drawer-hero {
      grid-template-columns: 1fr;
      padding: 4rem 1.5rem 2rem;
    }
    .drawer-hero__image-wrap { order: -1; }
    .drawer-hero__image { max-width: 260px; }
    .drawer-specs-section { padding: 2rem 1.5rem; }
    .drawer-specs-grid { grid-template-columns: repeat(2, 1fr); }
    .drawer-ergo { grid-template-columns: 1fr; }
    .drawer-ergo__image-wrap { height: 280px; }
    .drawer-ergo__overlay { background: linear-gradient(to bottom, transparent 50%, #0e0c09); }
    .drawer-ergo__content { padding: 2rem 1.5rem; }
  }
</style>
