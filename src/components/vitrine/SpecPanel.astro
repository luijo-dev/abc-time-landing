---
import SpecItem from './SpecItem.astro';

interface WatchSpec {
  label: string;
  value: string;
}

interface Props {
  specs: WatchSpec[];
  index?: number;
  isActive?: boolean;
}

const { specs, index = 0, isActive = false } = Astro.props;
---

<article
  class:list={['spec-panel', { 'is-hidden': !isActive }]}
  data-spec-panel
  data-spec-index={index}
  aria-hidden={isActive ? 'false' : 'true'}
  aria-label={`Especificaciones del reloj ${index + 1}`}
>
  {specs.map((spec) => (
    <SpecItem label={spec.label} value={spec.value} />
  ))}
</article>

<style>
  .spec-panel {
    display: grid;
    gap: var(--space-24);
    transition: opacity var(--transition-precision);
    grid-area: 1 / 1;
  }

  .spec-panel.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  @media (min-width: 720px) {
    .spec-panel {
      gap: var(--space-32);
    }
  }
</style>
