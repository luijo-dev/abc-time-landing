---
import SpecItem from './SpecItem.astro';

interface WatchSpec {
  label: string;
  value: string;
}

interface Props {
  specs: WatchSpec[];
  index?: number;
  isActive?: boolean;
}

const { specs, index = 0, isActive = false } = Astro.props;
---

<article
  class:list={['spec-panel', { 'is-hidden': !isActive }]}
  data-spec-panel
  data-spec-index={index}
  aria-hidden={isActive ? 'false' : 'true'}
  aria-label={`Especificaciones del reloj ${index + 1}`}
>
  {specs.map((spec) => (
    <SpecItem label={spec.label} value={spec.value} />
  ))}
</article>

<style>
  .spec-panel {
    display: grid;
    gap: var(--space-8);
    padding: var(--space-24);
    border: 1px solid rgb(var(--color-outline-variant-rgb) / 0.15);
    border-radius: calc(var(--radius-lg) + var(--space-4));
    background: rgb(var(--color-surface-variant-rgb) / 0.6);
    backdrop-filter: blur(var(--blur-glass));
    -webkit-backdrop-filter: blur(var(--blur-glass));
    box-shadow: var(--shadow-ambient);
  }

  .spec-panel.is-hidden {
    display: none;
  }

  @media (min-width: 720px) and (max-width: 1023px) {
    .spec-panel {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-16);
      align-items: start;
    }
  }

  @media (min-width: 1024px) {
    .spec-panel {
      gap: var(--space-12);
    }
  }
</style>
