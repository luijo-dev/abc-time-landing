---
import type { FeaturedWatch } from '../../types/homepage';
import WatchCarouselItem from './WatchCarouselItem.astro';
import WatchImage from './WatchImage.astro';

interface Props {
  items: FeaturedWatch[];
}

const { items } = Astro.props;
---

<section
  class="watch-carousel"
  data-carousel
  data-active-index="0"
  aria-label="Vitrina principal de relojes"
>
  <div
    class="watch-carousel__track"
    data-carousel-track
    role="listbox"
    aria-label="Selección de relojes destacados"
  >
    {items.map((item, index) => (
      <WatchCarouselItem
        item={item}
        index={index}
        isActive={index === 0}
      >
        <WatchImage
          src={item.image?.src}
          alt={item.image?.alt ?? `${item.collection} ${item.name}`}
          priority={item.image?.priority}
        />
      </WatchCarouselItem>
    ))}
  </div>

  <div class="watch-carousel__controls" aria-label="Navegación del carrusel">
    <button
      type="button"
      class="watch-carousel__nav-btn"
      data-carousel-prev
      aria-label="Reloj anterior"
    >
      <span aria-hidden="true">←</span>
    </button>
    <div class="watch-carousel__indicators" role="tablist" aria-label="Seleccionar reloj">
      {items.map((_, index) => (
        <button
          type="button"
          class:list={['watch-carousel__indicator', { 'is-active': index === 0 }]}
          data-carousel-indicator={index}
          role="tab"
          aria-selected={index === 0 ? 'true' : 'false'}
          aria-label={`Reloj ${index + 1}`}
        />
      ))}
    </div>
    <button
      type="button"
      class="watch-carousel__nav-btn"
      data-carousel-next
      aria-label="Siguiente reloj"
    >
      <span aria-hidden="true">→</span>
    </button>
  </div>
</section>

<script is:inline>
  const carouselRoot = document.currentScript?.previousElementSibling?.parentElement?.querySelector('[data-carousel]');

  if (carouselRoot instanceof HTMLElement) {
    const vitrineScope = carouselRoot.closest('.vitrine-shell') ?? document;
    const items = Array.from(carouselRoot.querySelectorAll('[data-carousel-item]'));
    const specPanels = Array.from(vitrineScope.querySelectorAll('[data-spec-panel]'));
    const ctaLink = vitrineScope.querySelector('[data-vitrine-cta-link]');
    const ctaCopy = vitrineScope.querySelector('[data-vitrine-cta-copy]');
    const stageName = vitrineScope.querySelector('[data-watch-stage-name]');
    const stageCollection = vitrineScope.querySelector('[data-watch-stage-collection]');
    const headerCta = vitrineScope.querySelector('[data-header-cta]');
    const indicators = Array.from(carouselRoot.querySelectorAll('[data-carousel-indicator]'));
    const prevBtn = carouselRoot.querySelector('[data-carousel-prev]');
    const nextBtn = carouselRoot.querySelector('[data-carousel-next]');
    const background = vitrineScope.querySelector('[data-vitrine-background]');
    const totalItems = items.length;
    let wheelDelta = 0;

    const getSlot = (index, activeIndex) => {
      const rawOffset = index - activeIndex;
      const wrapOffset = rawOffset > totalItems / 2
        ? rawOffset - totalItems
        : rawOffset < -totalItems / 2
          ? rawOffset + totalItems
          : rawOffset;

      if (wrapOffset === 0) return 'active';
      if (wrapOffset === -1) return 'prev';
      if (wrapOffset === 1) return 'next';
      if (wrapOffset < 0) return 'far-prev';
      return 'far-next';
    };

    const setActive = (rawIndex, shouldFocus = false) => {
      const nextIndex = ((rawIndex % totalItems) + totalItems) % totalItems;

      items.forEach((item, index) => {
        const isActive = index === nextIndex;
        const slot = getSlot(index, nextIndex);
        const isAdjacent = slot === 'prev' || slot === 'next';
        const isBackground = slot === 'far-prev' || slot === 'far-next';

        item.classList.toggle('is-active', isActive);
        item.classList.toggle('is-adjacent', isAdjacent && !isActive);
        item.classList.toggle('is-background', isBackground);
        item.setAttribute('data-slot', slot);
        item.setAttribute('aria-selected', String(isActive));
        if (isActive) {
          item.setAttribute('aria-current', 'true');
        } else {
          item.removeAttribute('aria-current');
        }
        item.tabIndex = isActive ? 0 : -1;
      });

      specPanels.forEach((panel) => {
        const isActive = panel.getAttribute('data-spec-index') === String(nextIndex);
        panel.classList.toggle('is-hidden', !isActive);
        panel.setAttribute('aria-hidden', String(!isActive));
      });

      indicators.forEach((dot, index) => {
        dot.classList.toggle('is-active', index === nextIndex);
        dot.setAttribute('aria-selected', String(index === nextIndex));
      });

      const activeItem = items[nextIndex];
      if (ctaLink instanceof HTMLAnchorElement && activeItem instanceof HTMLElement) {
        ctaLink.href = activeItem.dataset.ctaUrl ?? ctaLink.href;
        if (ctaCopy instanceof HTMLElement) {
          ctaCopy.textContent = activeItem.dataset.ctaLabel ?? 'Hablar por WhatsApp';
        }
        const watchName = activeItem.dataset.watchName ?? '';
        const watchCollection = activeItem.dataset.watchCollection ?? '';
        ctaLink.setAttribute('aria-label', `Hablar por WhatsApp sobre ${watchCollection} ${watchName}`);
      }

      if (activeItem instanceof HTMLElement) {
        if (stageName instanceof HTMLElement) {
          stageName.textContent = activeItem.dataset.watchName ?? '';
        }

        if (stageCollection instanceof HTMLElement) {
          stageCollection.textContent = activeItem.dataset.watchCollection ?? '';
        }
      }

      // Update header CTA
      if (headerCta instanceof HTMLAnchorElement && activeItem instanceof HTMLElement) {
        headerCta.href = activeItem.dataset.ctaUrl ?? headerCta.href;
      }

      // Update background mood
      if (background instanceof HTMLElement && activeItem instanceof HTMLElement) {
        const mood = activeItem.dataset.mood;
        background.className = 'vitrine-background';
        if (mood) {
          background.classList.add(`vitrine-background--${mood}`);
        }
      }

      carouselRoot.dataset.activeIndex = String(nextIndex);

      if (shouldFocus) {
        activeItem?.focus();
      }
    };

    // Click on items
    items.forEach((item, index) => {
      item.addEventListener('click', () => setActive(index));
      item.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowRight' || event.key === 'ArrowDown') {
          event.preventDefault();
          setActive(index + 1, true);
        }
        if (event.key === 'ArrowLeft' || event.key === 'ArrowUp') {
          event.preventDefault();
          setActive(index - 1, true);
        }
        if (event.key === 'Home') {
          event.preventDefault();
          setActive(0, true);
        }
        if (event.key === 'End') {
          event.preventDefault();
          setActive(totalItems - 1, true);
        }
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          setActive(index, true);
        }
      });
    });

    // Previous / Next buttons
    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        const current = Number(carouselRoot.dataset.activeIndex ?? '0');
        setActive(current - 1, true);
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        const current = Number(carouselRoot.dataset.activeIndex ?? '0');
        setActive(current + 1, true);
      });
    }

    // Indicator dots
    indicators.forEach((dot, index) => {
      dot.addEventListener('click', () => setActive(index, true));
    });

    carouselRoot.addEventListener(
      'wheel',
      (event) => {
        if (totalItems <= 1) return;

        event.preventDefault();

        const dominantDelta = Math.abs(event.deltaY) >= Math.abs(event.deltaX)
          ? event.deltaY
          : event.deltaX;

        wheelDelta += dominantDelta;

        if (Math.abs(wheelDelta) < 40) return;

        const current = Number(carouselRoot.dataset.activeIndex ?? '0');
        setActive(current + (wheelDelta > 0 ? 1 : -1), true);
        wheelDelta = 0;
      },
      { passive: false }
    );

    // Initialize
    setActive(Number(carouselRoot.dataset.activeIndex ?? '0'));
  }
</script>

<style>
  .watch-carousel {
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    height: 100%;
    min-height: 0;
    min-width: 0;
  }

  .watch-carousel__track {
    --carousel-stage-height: clamp(22rem, 62vh, 33rem);
    --watch-shell-height-active: clamp(17rem, 47vh, 24rem);
    --watch-shell-height-adjacent: clamp(14.25rem, 39vh, 18.75rem);
    --watch-shell-height-far: clamp(12.5rem, 33vh, 15.5rem);
    --watch-shell-width-active: clamp(15rem, 41vw, 24rem);
    --watch-shell-width-adjacent: clamp(12.75rem, 32vw, 18rem);
    --watch-shell-width-far: clamp(11.5rem, 27vw, 15rem);
    --slot-offset-adjacent: clamp(6.5rem, 19vw, 12rem);
    --slot-offset-far: clamp(10.5rem, 29vw, 19rem);
    --slot-drop-active: calc(var(--space-4) * -1);
    --slot-drop-adjacent: var(--space-24);
    --slot-drop-far: var(--space-48);
    position: relative;
    display: grid;
    place-items: center;
    overflow: visible;
    min-height: 0;
    height: 100%;
  }

  .watch-carousel__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-16);
    margin-top: var(--space-16);
  }

  .watch-carousel__nav-btn {
    display: inline-grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border: none;
    border-radius: 999px;
    background: rgb(var(--color-surface-variant-rgb) / 0.6);
    color: var(--color-on-surface-variant);
    font-size: 1rem;
    cursor: pointer;
    transition:
      color var(--transition-precision),
      background var(--transition-precision);
  }

  .watch-carousel__nav-btn:hover,
  .watch-carousel__nav-btn:focus-visible {
    color: var(--color-primary);
    background: rgb(var(--color-surface-variant-rgb) / 0.6);
  }

  .watch-carousel__indicators {
    display: flex;
    gap: var(--space-8);
  }

  .watch-carousel__indicator {
    width: var(--space-8);
    height: var(--space-8);
    border-radius: 999px;
    border: none;
    background: rgb(var(--color-outline-variant-rgb) / 0.3);
    cursor: pointer;
    transition:
      background var(--transition-precision),
      transform var(--transition-precision);
  }

  .watch-carousel__indicator.is-active {
    background: var(--color-primary);
    transform: scale(1.25);
  }

  .watch-carousel__indicator:hover:not(.is-active) {
    background: rgb(var(--color-outline-variant-rgb) / 0.6);
  }

  .watch-carousel__indicator:focus-visible {
    outline: 2px solid rgb(var(--color-primary-rgb) / 0.75);
    outline-offset: 2px;
  }

  @media (min-width: 1024px) {
    .watch-carousel__track {
      --carousel-stage-height: clamp(28rem, 72vh, 42rem);
      --watch-shell-height-active: clamp(21.5rem, 56vh, 31rem);
      --watch-shell-height-adjacent: clamp(17.5rem, 45vh, 24rem);
      --watch-shell-height-far: clamp(15.25rem, 37vh, 19.25rem);
      --watch-shell-width-active: clamp(19rem, 32vw, 28rem);
      --watch-shell-width-adjacent: clamp(15.75rem, 24vw, 21rem);
      --watch-shell-width-far: clamp(13.75rem, 19vw, 18rem);
      --slot-offset-adjacent: clamp(9rem, 18vw, 17rem);
      --slot-offset-far: clamp(14rem, 27vw, 24rem);
      --slot-drop-active: calc(var(--space-8) * -1);
      --slot-drop-adjacent: var(--space-32);
      --slot-drop-far: calc(var(--space-64) * 1.5);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .watch-carousel__nav-btn,
    .watch-carousel__indicator {
      transition: none;
    }
  }
</style>
