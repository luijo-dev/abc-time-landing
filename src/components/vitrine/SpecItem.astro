---
interface Props {
  label: string;
  value: string;
}

const { label, value } = Astro.props;
---

<div class="spec-item">
  <div class="spec-item__body">
    <span class="spec-item__label">{label}</span>
    <span class="spec-item__value">{value}</span>
  </div>
</div>

<style>
  .spec-item {
    display: grid;
    gap: var(--space-2);
    padding: var(--space-8) 0;
  }

  .spec-item__body {
    display: grid;
    gap: var(--space-2);
  }

  .spec-item__label {
    color: var(--color-on-surface-variant);
    font-family: var(--font-body);
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .spec-item__value {
    color: var(--color-on-surface);
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 2.5vw, 1.45rem);
    line-height: 1.2;
  }
</style>
