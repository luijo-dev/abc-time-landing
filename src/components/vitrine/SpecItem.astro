---
interface Props {
  icon: string;
  label: string;
  value: string;
}
---

<div class="spec-item">
  <span class="spec-item__icon" aria-hidden="true">{Astro.props.icon}</span>
  <div class="spec-item__body">
    <span class="spec-item__label">{Astro.props.label}</span>
    <span class="spec-item__value">{Astro.props.value}</span>
  </div>
</div>

<style>
  .spec-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-16);
    align-items: center;
    padding: var(--space-16) 0;
  }

  .spec-item__icon {
    display: inline-grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 999px;
    background: rgb(var(--color-surface-variant-rgb) / 0.42);
    box-shadow:
      inset 0 0 0 1px rgb(var(--color-outline-variant-rgb) / 0.18),
      0 12px 24px rgb(var(--color-shadow-rgb) / 0.16);
    font-size: 1rem;
  }

  .spec-item__body {
    display: grid;
    gap: var(--space-4);
  }

  .spec-item__label {
    color: var(--color-on-surface-variant);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: var(--letter-spacing-label);
    line-height: 1.2;
    text-transform: uppercase;
  }

  .spec-item__value {
    color: var(--color-on-surface);
    font-family: var(--font-serif);
    font-size: clamp(1.125rem, 2vw, 1.35rem);
    line-height: 1.35;
  }
</style>
