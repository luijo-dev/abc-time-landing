---
interface Props {
  name: string;
  collection: string;
}
---

<div class="watch-title">
  <h2 id="vitrine-heading" class="watch-title__name" data-watch-stage-name>{Astro.props.name}</h2>
  <p class="watch-title__collection">
    <span class="watch-title__collection-line" aria-hidden="true"></span>
    <span data-watch-stage-collection>{Astro.props.collection}</span>
  </p>
</div>

<style>
  .watch-title {
    display: grid;
    gap: var(--space-8);
    align-content: start;
  }

  .watch-title__collection {
    display: inline-flex;
    align-items: center;
    gap: var(--space-12);
    color: var(--color-on-surface-variant);
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1.4;
    margin: 0;
  }

  .watch-title__collection-line {
    width: 2.75rem;
    min-width: 2.75rem;
    height: 1px;
    background: rgb(var(--color-outline-variant-rgb) / 0.45);
  }

  .watch-title__name {
    color: var(--color-primary);
    font-family: var(--font-display);
    font-size: clamp(2.125rem, 4vw, 3rem);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-display);
    line-height: var(--line-height-tight);
    text-wrap: balance;
    margin: 0;
  }
</style>
