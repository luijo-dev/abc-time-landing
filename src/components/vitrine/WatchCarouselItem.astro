---
import WatchTitle from './WatchTitle.astro';

interface Watch {
  id: string;
  name: string;
  collection: string;
  imageSrc?: string;
  imageAlt: string;
  specs: Array<{
    icon: string;
    label: string;
    value: string;
  }>;
  ctaUrl: string;
}

interface Props {
  item: Watch;
  isActive?: boolean;
  index: number;
}

const { item, isActive = false, index } = Astro.props;
---

<button
  type="button"
  class:list={['watch-carousel-item', { 'is-active': isActive }]}
  data-carousel-item
  data-index={index}
  data-cta-url={item.ctaUrl}
  role="option"
  aria-label={`Ver ${item.collection} ${item.name}`}
  aria-selected={isActive ? 'true' : 'false'}
  aria-current={isActive ? 'true' : undefined}
  tabindex={isActive ? '0' : '-1'}
>
  <span class="watch-carousel-item__media">
    <slot />
  </span>

  <span class="watch-carousel-item__title">
    <WatchTitle name={item.name} collection={item.collection} />
  </span>
</button>

<style>
  .watch-carousel-item {
    position: relative;
    flex: 0 0 var(--vitrine-carousel-item-mobile);
    scroll-snap-align: center;
    display: grid;
    gap: var(--space-16);
    width: 100%;
    padding: var(--space-16);
    border: 1px solid rgb(var(--color-outline-variant-rgb) / 0.14);
    border-radius: calc(var(--radius-lg) + var(--space-4));
    background: linear-gradient(180deg, rgb(255 255 255 / 0.03), rgb(16 16 16 / 0.72));
    box-shadow: 0 24px 60px rgb(var(--color-shadow-rgb) / 0.28);
    color: inherit;
    cursor: pointer;
    opacity: 0.6;
    overflow: hidden;
    transform: scale(0.9) translateY(var(--space-8));
    filter: saturate(0.3);
    transition:
      transform var(--transition-precision),
      opacity var(--transition-precision),
      filter var(--transition-precision),
      box-shadow var(--transition-precision),
      border-color var(--transition-precision);
  }

  .watch-carousel-item::after {
    content: '';
    position: absolute;
    inset: auto 12% 0;
    height: 32%;
    background: linear-gradient(180deg, transparent, rgb(0 0 0 / 0.72));
    pointer-events: none;
  }

  .watch-carousel-item:hover {
    border-color: rgb(var(--color-outline-variant-rgb) / 0.24);
    opacity: 0.78;
    filter: saturate(0.65);
  }

  .watch-carousel-item.is-active {
    opacity: 1;
    transform: scale(1) translateY(0);
    filter: saturate(1);
    border-color: rgb(242 202 80 / 0.34);
    box-shadow:
      0 30px 72px rgb(var(--color-shadow-rgb) / 0.4),
      inset 0 0 0 1px rgb(242 202 80 / 0.12);
  }

  .watch-carousel-item:focus-visible {
    outline: 2px solid rgb(242 202 80 / 0.75);
    outline-offset: 4px;
  }

  .watch-carousel-item__media,
  .watch-carousel-item__title {
    position: relative;
    z-index: 1;
  }

  .watch-carousel-item__title {
    position: absolute;
    right: var(--space-16);
    bottom: var(--space-16);
    left: var(--space-16);
    padding-top: var(--space-32);
  }

  @media (min-width: 1024px) {
    .watch-carousel-item {
      flex-basis: var(--vitrine-carousel-item-desktop);
      padding: var(--space-24);
    }

    .watch-carousel-item__title {
      right: var(--space-24);
      bottom: var(--space-24);
      left: var(--space-24);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .watch-carousel-item,
    .watch-carousel-item:hover,
    .watch-carousel-item.is-active {
      transform: none;
    }
  }
</style>
