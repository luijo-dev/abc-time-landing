---
import type { FeaturedWatch } from '../../types/homepage';

interface Props {
  item: FeaturedWatch;
  isActive?: boolean;
  index: number;
}

const { item, isActive = false, index } = Astro.props;
---

<button
  type="button"
  class:list={[
    'watch-carousel-item',
    { 'is-active': isActive },
  ]}
  data-carousel-item
  data-index={index}
  data-cta-url={item.ctaUrl}
  data-cta-label={item.ctaLabel ?? 'Hablar por WhatsApp'}
  data-watch-name={item.name}
  data-watch-collection={item.collection}
  data-mood={item.mood ?? ''}
  role="option"
  aria-label={`Ver ${item.collection} ${item.name}`}
  aria-selected={isActive ? 'true' : 'false'}
  aria-current={isActive ? 'true' : undefined}
  tabindex={isActive ? '0' : '-1'}
>
  <span class="watch-carousel-item__media">
    <slot />
  </span>

</button>

<style>
  .watch-carousel-item {
    --item-padding: var(--space-8);
    --watch-shell-height: var(--watch-shell-height-far);
    --watch-shell-width: var(--watch-shell-width-far);
    --watch-media-height: calc(var(--watch-shell-height) - (var(--item-padding) * 2));
    --watch-media-width: calc(var(--watch-shell-width) - (var(--item-padding) * 1.2));
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(var(--vitrine-carousel-item-mobile), var(--watch-shell-width));
    max-width: 100%;
    height: min(var(--watch-shell-height), var(--carousel-stage-height));
    max-height: var(--carousel-stage-height);
    padding: var(--item-padding);
    border: none;
    border-radius: calc(var(--radius-lg) + var(--space-4));
    background: transparent;
    box-shadow: none;
    color: inherit;
    cursor: pointer;
    overflow: visible;
    opacity: 0.46;
    transform: translate3d(calc(var(--slot-offset-far) * -1), var(--slot-drop-far), 0) scale(0.84);
    filter: saturate(0.42) blur(0.18px);
    z-index: 1;
    grid-area: 1 / 1;
    transition:
      transform var(--transition-precision),
      opacity var(--transition-precision),
      filter var(--transition-precision),
      box-shadow var(--transition-precision);
  }

  /* Adjacent watches: midground depth */
  .watch-carousel-item.is-adjacent {
    --watch-shell-height: var(--watch-shell-height-adjacent);
    --watch-shell-width: var(--watch-shell-width-adjacent);
    opacity: 0.82;
    filter: saturate(0.7);
    z-index: 2;
  }

  /* Hover on any state */
  .watch-carousel-item:hover:not(.is-active) {
    opacity: 0.82;
    filter: saturate(0.72);
    box-shadow: none;
    outline: none;
  }

  /* Active watch: foreground emphasis */
  .watch-carousel-item.is-active {
    --watch-shell-height: var(--watch-shell-height-active);
    --watch-shell-width: var(--watch-shell-width-active);
    opacity: 1;
    transform: translate3d(0, var(--slot-drop-active), 0) scale(1);
    filter: saturate(1);
    z-index: 5;
  }

  .watch-carousel-item:focus-visible {
    outline: none;
  }

  .watch-carousel-item__media {
    position: relative;
    z-index: 1;
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    overflow: visible;
    /* Ajuste para compensar el margen transparente desigual de las imágenes */
    transform: translateY(-20%);
  }

  .watch-carousel-item[data-slot='prev'] {
    transform: translate3d(calc(var(--slot-offset-adjacent) * -1), var(--slot-drop-adjacent), 0) scale(0.85);
  }

  .watch-carousel-item[data-slot='next'] {
    transform: translate3d(var(--slot-offset-adjacent), var(--slot-drop-adjacent), 0) scale(0.85);
  }

  .watch-carousel-item[data-slot='far-prev'] {
    transform: translate3d(calc(var(--slot-offset-far) * -1), var(--slot-drop-far), 0) scale(0.70);
  }

  .watch-carousel-item[data-slot='far-next'] {
    transform: translate3d(var(--slot-offset-far), var(--slot-drop-far), 0) scale(0.70);
  }

  @media (min-width: 1024px) {
    .watch-carousel-item {
      --item-padding: var(--space-10);
      --watch-media-height: calc(var(--watch-shell-height) - (var(--item-padding) * 2));
      --watch-media-width: calc(var(--watch-shell-width) - (var(--item-padding) * 1.2));
      width: min(var(--vitrine-carousel-item-desktop), var(--watch-shell-width));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .watch-carousel-item,
    .watch-carousel-item:hover,
    .watch-carousel-item.is-active,
    .watch-carousel-item.is-adjacent {
      transition-duration: 0s;
    }

    .watch-carousel-item {
      filter: none;
    }
  }
</style>
