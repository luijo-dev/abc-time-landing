---
import type { FeaturedWatch } from '../../types/homepage';

interface Props {
  item: FeaturedWatch;
  isActive?: boolean;
  index: number;
}

const { item, isActive = false, index } = Astro.props;
---

<button
  type="button"
  class:list={[
    'watch-carousel-item',
    { 'is-active': isActive },
  ]}
  data-carousel-item
  data-index={index}
  data-cta-url={item.ctaUrl}
  data-cta-label={item.ctaLabel ?? 'Hablar por WhatsApp'}
  data-watch-name={item.name}
  data-watch-collection={item.collection}
  data-mood={item.mood ?? ''}
  role="option"
  aria-label={`Ver ${item.collection} ${item.name}`}
  aria-selected={isActive ? 'true' : 'false'}
  aria-current={isActive ? 'true' : undefined}
  tabindex={isActive ? '0' : '-1'}
>
  <span class="watch-carousel-item__media">
    <slot />
  </span>

</button>

<style>
  .watch-carousel-item {
    position: absolute;
    display: grid;
    gap: var(--space-16);
    width: var(--vitrine-carousel-item-mobile);
    max-width: 100%;
    padding: var(--space-16);
    border: 1px solid rgb(var(--color-outline-variant-rgb) / 0.15);
    border-radius: calc(var(--radius-lg) + var(--space-4));
    background: linear-gradient(
      180deg,
      rgb(var(--color-surface-variant-rgb) / 0.6),
      rgb(var(--color-shadow-rgb) / 0.72)
    );
    box-shadow: var(--shadow-ambient);
    color: inherit;
    cursor: pointer;
    overflow: hidden;
    /* Spatial staging defaults: background state */
    opacity: 0.4;
    transform: scale(0.78) translateY(var(--space-12));
    filter: saturate(0.2) blur(1px);
    z-index: 1;
    grid-area: 1 / 1;
    transition:
      transform var(--transition-precision),
      opacity var(--transition-precision),
      filter var(--transition-precision),
      box-shadow var(--transition-precision),
      border-color var(--transition-precision);
  }

  .watch-carousel-item::after {
    content: '';
    position: absolute;
    inset: auto 12% 0;
    height: 32%;
    background: linear-gradient(180deg, transparent, rgb(var(--color-shadow-rgb) / 0.72));
    pointer-events: none;
  }

  /* Adjacent watches: midground depth */
  .watch-carousel-item.is-adjacent {
    opacity: 0.65;
    transform: scale(0.88) translateY(var(--space-4));
    filter: saturate(0.5);
    z-index: 2;
    border-color: rgb(var(--color-outline-variant-rgb) / 0.2);
  }

  /* Hover on any state */
  .watch-carousel-item:hover:not(.is-active) {
    border-color: rgb(var(--color-outline-variant-rgb) / 0.2);
    opacity: 0.78;
    filter: saturate(0.65);
  }

  /* Active watch: foreground emphasis */
  .watch-carousel-item.is-active {
    opacity: 1;
    transform: scale(1) translateY(0);
    filter: saturate(1);
    z-index: 5;
    border-color: rgb(var(--color-primary-rgb) / 0.34);
    box-shadow:
      var(--shadow-ambient),
      inset 0 0 0 1px rgb(var(--color-primary-rgb) / 0.12);
  }

  .watch-carousel-item:focus-visible {
    outline: 2px solid rgb(var(--color-primary-rgb) / 0.75);
    outline-offset: 4px;
  }

  .watch-carousel-item__media {
    position: relative;
    z-index: 1;
  }

  @media (min-width: 1024px) {
    .watch-carousel-item {
      flex-basis: var(--vitrine-carousel-item-desktop);
      width: var(--vitrine-carousel-item-desktop);
      padding: var(--space-24);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .watch-carousel-item,
    .watch-carousel-item:hover,
    .watch-carousel-item.is-active,
    .watch-carousel-item.is-adjacent {
      transform: none;
      filter: none;
      transition-duration: 0s;
    }

    .watch-carousel-item {
      opacity: 0.5;
    }

    .watch-carousel-item.is-adjacent {
      opacity: 0.7;
    }

    .watch-carousel-item.is-active {
      opacity: 1;
    }
  }
</style>
