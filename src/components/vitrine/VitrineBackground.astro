---
interface Props {
  mood?: 'gold' | 'smoke';
}

const { mood } = Astro.props;
---

<div
  class:list={['vitrine-background', { [`vitrine-background--${mood}`]: mood }]}
  data-vitrine-background
  aria-hidden="true"
></div>

<style>
  .vitrine-background {
    position: fixed;
    inset: 0;
    z-index: 0;
    background: 
      linear-gradient(
        to top left,
        rgb(140 115 70 / 0.28) 0%,
        rgb(100 85 55 / 0.1) 35%,
        transparent 60%
      ),
      #0c0a08;
    transition: background var(--transition-precision);
  }

  /* Gold mood: warmer */
  .vitrine-background--gold {
    background: 
      linear-gradient(
        to top left,
        rgb(160 130 65 / 0.32) 0%,
        rgb(115 90 45 / 0.12) 35%,
        transparent 60%
      ),
      #0c0a08;
  }

  /* Smoke mood: cooler, olive tones */
  .vitrine-background--smoke {
    background: 
      linear-gradient(
        to top left,
        rgb(110 105 85 / 0.22) 0%,
        rgb(85 80 65 / 0.08) 35%,
        transparent 60%
      ),
      #0a0a0a;
  }

  @media (prefers-reduced-motion: reduce) {
    .vitrine-background {
      transition: none;
    }
  }
</style>
