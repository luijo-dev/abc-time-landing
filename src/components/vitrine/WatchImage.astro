---
interface Props {
  src?: string;
  alt: string;
  priority?: boolean;
}

const { src, alt, priority = false } = Astro.props;
---

<figure class="watch-image" data-watch-image-root>
  {src ? (
    <>
      <img
        class="watch-image__asset"
        src={src}
        alt={alt}
        loading={priority ? 'eager' : 'lazy'}
        decoding={priority ? 'sync' : 'async'}
        fetchpriority={priority ? 'high' : 'auto'}
        onerror="this.closest('[data-watch-image-root]')?.setAttribute('data-image-fallback', 'true'); this.remove();"
      />
      <div class="watch-image__placeholder" role="img" aria-label={alt}></div>
    </>
  ) : (
    <div class="watch-image__placeholder" role="img" aria-label={alt}></div>
  )}
</figure>

<style>
  .watch-image {
    display: grid;
    place-items: center;
    width: 100%;
    aspect-ratio: 3 / 4;
    margin: 0;
    border-radius: var(--radius-lg);
    background:
      radial-gradient(circle at 50% 32%, rgb(var(--color-primary-rgb) / 0.2), transparent 18%),
      linear-gradient(180deg, rgb(var(--color-surface-variant-rgb) / 0.6), rgb(var(--color-shadow-rgb) / 0.92));
    box-shadow: inset 0 0 0 1px rgb(var(--color-outline-variant-rgb) / 0.15);
    overflow: hidden;
  }

  .watch-image__asset,
  .watch-image__placeholder {
    width: 100%;
    height: 100%;
    aspect-ratio: 3 / 4;
  }

  .watch-image__asset {
    object-fit: contain;
  }

  .watch-image__asset + .watch-image__placeholder {
    display: none;
  }

  .watch-image[data-image-fallback='true'] .watch-image__placeholder {
    display: block;
  }

  .watch-image__placeholder {
    position: relative;
    border-radius: inherit;
    background:
      radial-gradient(circle at 50% 28%, rgb(var(--color-primary-rgb) / 0.24), transparent 16%),
      linear-gradient(180deg, rgb(var(--color-surface-variant-rgb) / 0.6), rgb(var(--color-shadow-rgb) / 0.96));
  }

  .watch-image__placeholder::before,
  .watch-image__placeholder::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    border-radius: 999px;
    pointer-events: none;
  }

  .watch-image__placeholder::before {
    top: 12%;
    width: 34%;
    height: 34%;
    border: 1px solid rgb(var(--color-outline-variant-rgb) / 0.2);
    box-shadow:
      0 0 0 1px rgb(var(--color-primary-rgb) / 0.08),
      inset 0 0 18px rgb(var(--color-surface-variant-rgb) / 0.3);
  }

  .watch-image__placeholder::after {
    top: 47%;
    width: 12%;
    height: 28%;
    background: linear-gradient(
      180deg,
      rgb(var(--color-primary-rgb) / 0.2),
      rgb(var(--color-primary-container-rgb) / 0.08)
    );
    box-shadow: 0 0 24px rgb(var(--color-primary-rgb) / 0.08);
  }
</style>
