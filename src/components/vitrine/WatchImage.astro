---
interface Props {
  src?: string;
  alt: string;
}
---

<figure class="watch-image">
  {Astro.props.src ? (
    <img class="watch-image__asset" src={Astro.props.src} alt={Astro.props.alt} loading="lazy" decoding="async" />
  ) : (
    <div class="watch-image__placeholder" role="img" aria-label={Astro.props.alt}></div>
  )}
</figure>

<style>
  .watch-image {
    display: grid;
    place-items: center;
    width: 100%;
    aspect-ratio: 3 / 4;
    margin: 0;
    border-radius: var(--radius-lg);
    background:
      radial-gradient(circle at 50% 32%, rgb(242 202 80 / 0.24), transparent 18%),
      linear-gradient(160deg, rgb(255 255 255 / 0.03), transparent 36%),
      linear-gradient(180deg, rgb(var(--color-surface-variant-rgb) / 0.72), rgb(14 14 14 / 0.92));
    box-shadow: inset 0 0 0 1px rgb(var(--color-outline-variant-rgb) / 0.15);
    overflow: hidden;
  }

  .watch-image__asset,
  .watch-image__placeholder {
    width: 100%;
    height: 100%;
    aspect-ratio: 3 / 4;
  }

  .watch-image__asset {
    object-fit: contain;
  }

  .watch-image__placeholder {
    position: relative;
    border-radius: inherit;
    background:
      radial-gradient(circle at 50% 28%, rgb(242 202 80 / 0.28), transparent 16%),
      radial-gradient(circle at 50% 52%, rgb(255 255 255 / 0.08), transparent 20%),
      linear-gradient(180deg, rgb(255 255 255 / 0.04), transparent 24%),
      linear-gradient(180deg, rgb(20 20 20 / 0.88), rgb(10 10 10 / 0.98));
  }

  .watch-image__placeholder::before,
  .watch-image__placeholder::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    border-radius: 999px;
    pointer-events: none;
  }

  .watch-image__placeholder::before {
    top: 12%;
    width: 34%;
    height: 34%;
    border: 1px solid rgb(var(--color-outline-variant-rgb) / 0.24);
    box-shadow:
      0 0 0 1px rgb(242 202 80 / 0.08),
      inset 0 0 18px rgb(255 255 255 / 0.04);
  }

  .watch-image__placeholder::after {
    top: 47%;
    width: 12%;
    height: 28%;
    background: linear-gradient(180deg, rgb(242 202 80 / 0.2), rgb(255 255 255 / 0.02));
    box-shadow: 0 0 24px rgb(242 202 80 / 0.08);
  }
</style>
