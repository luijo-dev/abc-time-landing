---
interface Props {
  src?: string;
  alt: string;
  priority?: boolean;
  transitionName?: string;
}

const { src, alt, priority = false, transitionName } = Astro.props;
---

<figure class="watch-image" data-watch-image-root>
  {src ? (
    <>
      <img
        class="watch-image__asset"
        src={src}
        alt={alt}
        loading={priority ? 'eager' : 'lazy'}
        decoding={priority ? 'sync' : 'async'}
        fetchpriority={priority ? 'high' : 'auto'}
        transition:name={transitionName}
        onerror="this.closest('[data-watch-image-root]')?.setAttribute('data-image-fallback', 'true'); this.remove();"
      />
      <div class="watch-image__placeholder" role="img" aria-label={alt}></div>
    </>
  ) : (
    <div class="watch-image__placeholder" role="img" aria-label={alt}></div>
  )}
</figure>

<style>
  .watch-image {
    display: grid;
    place-items: center;
    width: min(100%, var(--watch-media-width, calc(var(--watch-media-height, 16rem) * 1.12)));
    max-width: 100%;
    height: min(100%, var(--watch-media-height, 16rem));
    max-height: var(--watch-media-height, 16rem);
    margin: 0;
    border-radius: var(--radius-lg);
    overflow: visible;
  }

  .watch-image__asset,
  .watch-image__placeholder {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    transition: transform var(--transition-precision);
    transform-origin: center center;
  }

  .watch-image__asset {
    object-fit: contain;
    object-position: center center;
  }

  :global(.watch-carousel-item:hover .watch-image__asset),
  :global(.watch-carousel-item:hover .watch-image__placeholder) {
    transform: scale(1.25);
  }

  .watch-image__asset + .watch-image__placeholder {
    display: none;
  }

  .watch-image[data-image-fallback='true'] .watch-image__placeholder {
    display: block;
  }

  .watch-image__placeholder {
    position: relative;
    border-radius: inherit;
    background:
      radial-gradient(circle at 50% 28%, rgb(var(--color-primary-rgb) / 0.24), transparent 16%),
      linear-gradient(180deg, rgb(var(--color-surface-variant-rgb) / 0.6), rgb(var(--color-shadow-rgb) / 0.96));
  }

  .watch-image__placeholder::before,
  .watch-image__placeholder::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    border-radius: 999px;
    pointer-events: none;
  }

  .watch-image__placeholder::before {
    top: 12%;
    width: 34%;
    height: 34%;
    box-shadow:
      inset 0 0 18px rgb(var(--color-surface-variant-rgb) / 0.3);
  }

  .watch-image__placeholder::after {
    top: 47%;
    width: 12%;
    height: 28%;
    background: linear-gradient(
      180deg,
      rgb(var(--color-primary-rgb) / 0.2),
      rgb(var(--color-primary-container-rgb) / 0.08)
    );
    box-shadow: 0 0 24px rgb(var(--color-primary-rgb) / 0.08);
  }

  @media (prefers-reduced-motion: reduce) {
    .watch-image__asset,
    .watch-image__placeholder {
      transition: none;
    }

    :global(.watch-carousel-item:hover .watch-image__asset),
    :global(.watch-carousel-item:hover .watch-image__placeholder) {
      transform: none;
    }
  }
</style>
