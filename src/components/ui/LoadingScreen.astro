---
import BrandText from './BrandText.astro';
import LoadingBar from './LoadingBar.astro';

interface Props {
  variant?: 'black' | 'transparent';
  minDuration?: number;
  showOn?: 'root' | 'all';
}

const {
  variant = 'black',
  minDuration = 2000,
  showOn = 'root',
}: Props = Astro.props;

const rootClassName = `loading-screen loading-screen--${variant}`;
---

<div class="loading-screen-root" data-loading-screen-root data-show-on={showOn} data-min-duration={minDuration}>
  <div class={rootClassName} data-loading-screen aria-hidden="true">
    <div class="loading-screen__content">
      <BrandText />
      <LoadingBar duration={2500} />
    </div>
  </div>

  <span class="loading-screen__live-region" data-loading-screen-live aria-live="polite" aria-atomic="true">
    Loading content
  </span>
</div>

<script is:inline>
  const loadingScreenRoot = document.querySelector('[data-loading-screen-root]');
  const loadingScreen = loadingScreenRoot?.querySelector('[data-loading-screen]');
  const loadingContent = loadingScreenRoot?.querySelector('.loading-screen__content');

  if (loadingScreenRoot instanceof HTMLElement && loadingScreen instanceof HTMLElement) {
    const minDuration = Number(loadingScreenRoot.dataset.minDuration ?? '2000');
    const pageReady = new Promise((resolve) => {
      if (document.readyState !== 'loading') {
        resolve();
        return;
      }

      document.addEventListener('DOMContentLoaded', () => resolve(), { once: true });
    });

    const timer = new Promise((resolve) => {
      window.setTimeout(resolve, minDuration);
    });

    Promise.all([pageReady, timer]).then(() => {
      loadingScreen.classList.add('loading-screen--fade-out');

      const removeLoadingScreen = () => {
        loadingScreenRoot.remove();
      };

      // Wait for content fade-out transition, then remove entire overlay
      if (loadingContent instanceof HTMLElement) {
        loadingContent.addEventListener('transitionend', removeLoadingScreen, { once: true });
      }
      window.setTimeout(removeLoadingScreen, 500);
    });
  }
</script>

<style>
  .loading-screen-root {
    position: fixed;
    inset: 0;
    z-index: 9999;
  }

  .loading-screen {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: grid;
    place-items: center;
    isolation: isolate;
    overflow: clip;
  }

  .loading-screen--black {
    background: var(--color-background);
  }

  .loading-screen--transparent {
    background: rgb(19 19 19 / 0.6);
    backdrop-filter: blur(4px);
  }

  .loading-screen--fade-out .loading-screen__content {
    opacity: 0;
    transition: opacity 400ms ease-out;
  }

  .loading-screen__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 1;
    transition: opacity 400ms ease-out;
  }

  .loading-screen__live-region {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .loading-screen--fade-out .loading-screen__content {
      transition: opacity 200ms ease-out;
    }
  }
</style>
