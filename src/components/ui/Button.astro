---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'tertiary';
  type?: 'button' | 'submit' | 'reset';
}

const { href, variant = 'primary', type = 'button' } = Astro.props;
const className = `button button--${variant}`;
---

{href ? (
  <a class={className} href={href}>
    <slot />
  </a>
) : (
  <button class={className} type={type}>
    <slot />
  </button>
)}

<style>
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
    min-height: 3rem;
    padding: 0.875rem 1.5rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition:
      transform var(--transition-precision),
      color var(--transition-precision),
      background var(--transition-precision),
      border-color var(--transition-precision);
  }

  .button:hover,
  .button:focus-visible {
    transform: translateY(-1px);
  }

  .button--primary {
    background: linear-gradient(45deg, var(--color-primary), var(--color-primary-container));
    color: var(--color-on-primary);
    box-shadow: var(--shadow-ambient);
  }

  .button--secondary {
    border: 1px solid rgb(var(--color-outline-variant-rgb) / 0.15);
    background: transparent;
    color: var(--color-primary);
  }

  .button--secondary:hover,
  .button--secondary:focus-visible {
    border-color: rgb(var(--color-outline-variant-rgb) / 0.28);
    background: rgb(var(--color-surface-variant-rgb) / 0.24);
  }

  .button--tertiary {
    position: relative;
    padding-inline: 0;
    color: var(--color-primary);
  }

  .button--tertiary::after {
    content: '';
    position: absolute;
    inset: auto 0 -0.125rem;
    height: 1px;
    transform: scaleX(0.4);
    transform-origin: left;
    background: linear-gradient(45deg, var(--color-primary), var(--color-primary-container));
    transition: transform var(--transition-precision);
  }

  .button--tertiary:hover::after,
  .button--tertiary:focus-visible::after {
    transform: scaleX(1);
  }
</style>
