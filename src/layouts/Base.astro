---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import LoadingScreen from '../components/ui/LoadingScreen.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'AVC TIME | Curaduría de alta relojería',
  description = 'Una experiencia editorial para descubrir piezas de alta relojería y continuar la conversación por WhatsApp.',
} = Astro.props;

const loadingScreenShowOn = 'root';
const shouldShowLoadingScreen =
  loadingScreenShowOn === 'all' || Astro.url.pathname === '/';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Serif:wght@400;500;600;700&display=swap"
    />
    <ClientRouter />
    <!-- Previene flash en hard reloads si ya se mostró -->
    <script is:inline>
      if (sessionStorage.getItem('splashShown') === 'true') {
        document.documentElement.classList.add('splash-done');
      }
    </script>
    <title>{title}</title>
  </head>
  <body>
    {shouldShowLoadingScreen && (
      <LoadingScreen variant="black" minDuration={2000} showOn={loadingScreenShowOn} />
    )}
    <slot />

    <script>
      function trackNavigation() {
        const current = window.location.pathname;
        const prev = sessionStorage.getItem('currentPath');
        if (prev && prev !== current) {
          sessionStorage.setItem('prevPath', prev);
        }
        sessionStorage.setItem('currentPath', current);

        const match = current.match(/^\/watches\/([^/]+)$/);
        if (match) {
          sessionStorage.setItem('activeWatchId', match[1]);
        }
      }

      // Run on every page load (initial and client-side transitions)
      document.addEventListener('astro:page-load', trackNavigation);

      // Previene flash en navegaciones de View Transitions (SPA) y restaura estado del carrusel
      document.addEventListener('astro:before-swap', (e) => {
        if (sessionStorage.getItem('splashShown') === 'true') {
          const splash = e.newDocument.querySelector('[data-loading-screen-root]');
          if (splash) {
            splash.remove();
          }
          e.newDocument.documentElement.classList.add('splash-done');
        }

        const carousel = e.newDocument.querySelector('[data-carousel]');
        if (carousel && (window as any).updateCarouselState) {
          const activeWatchId = sessionStorage.getItem('activeWatchId');
          if (activeWatchId) {
            const items = Array.from(carousel.querySelectorAll('[data-carousel-item]'));
            const targetIndex = items.findIndex(item => (item as HTMLElement).dataset.watchId === activeWatchId);
            if (targetIndex !== -1) {
              (window as any).updateCarouselState(carousel as HTMLElement, targetIndex);
            }
          }
        }
      });
    </script>
  </body>
</html>
