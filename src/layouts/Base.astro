---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import LoadingScreen from '../components/ui/LoadingScreen.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'AVC TIME | Curaduría de alta relojería',
  description = 'Una experiencia editorial para descubrir piezas de alta relojería y continuar la conversación por WhatsApp.',
} = Astro.props;

const loadingScreenShowOn = 'root';
const shouldShowLoadingScreen =
  loadingScreenShowOn === 'all' || Astro.url.pathname === '/';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Serif:wght@400;500;600;700&display=swap"
    />
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body>
    {shouldShowLoadingScreen && (
      <LoadingScreen variant="black" minDuration={2000} showOn={loadingScreenShowOn} />
    )}
    <slot />
  </body>
</html>
