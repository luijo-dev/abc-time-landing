---
import Base from '../../layouts/Base.astro';
import { watches, getWatchById } from '../../data/watches';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (() => {
  return watches.map((w) => ({ params: { id: w.id } }));
}) satisfies GetStaticPaths;

const { id } = Astro.params;
const watch = getWatchById(id);

if (!watch) {
  return Astro.redirect('/catalogo');
}

const detail = watch.detail;
---

<Base
  title={`${watch.name} — ${watch.collection} | AVC TIME`}
  description={detail?.description ?? `Descubre el ${watch.name} de ${watch.collection}. Consulta disponibilidad y precio por WhatsApp.`}
>
  <div class="watch-page">

    <!-- ── Navbar ── -->
    <header class="wp-nav">
      <a href="/catalogo" class="wp-nav__back" aria-label="Volver al catálogo">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
        Catálogo
      </a>
      <a href="/" class="wp-nav__brand">AVC TIME</a>
      <div class="wp-nav__spacer" aria-hidden="true"></div>
    </header>

    <!-- ── 1. HERO ── -->
    <section class="wp-hero">
      <div class="wp-hero__content">
        <p class="wp-eyebrow">{detail?.eyebrow ?? watch.collection}</p>
        <h1 class="wp-title">
          {watch.name.split(' ').map((word, i) => (
            <span class={i === watch.name.split(' ').length - 1 ? 'wp-title__accent' : ''}>{word} </span>
          ))}
        </h1>
        <p class="wp-collection">{watch.collection}</p>
        <p class="wp-description">{detail?.description}</p>

        <div class="wp-cta-row">
          <a
            href={watch.ctaUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
            aria-label={watch.ctaLabel ?? `Consultar ${watch.name} por WhatsApp`}
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.108.549 4.088 1.512 5.806L.057 23.535a.75.75 0 0 0 .908.908l5.727-1.454A11.94 11.94 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.891 0-3.667-.496-5.201-1.364l-.373-.214-3.861.98.998-3.861-.222-.385A9.957 9.957 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
            Consultar por WhatsApp
          </a>
          <a href="/catalogo" class="btn-secondary">Solicitar Visita</a>
        </div>
      </div>

      <div class="wp-hero__image-wrap">
        <div class="wp-hero__glow" aria-hidden="true"></div>
        {watch.image && (
          <img
            src={watch.image.src}
            alt={watch.image.alt}
            class="wp-hero__image"
            loading="eager"
            transition:name={`watch-img-${watch.id}`}
          />
        )}
      </div>
    </section>

    <!-- ── 2. TECHNICAL SPECS ── -->
    {detail?.specGroups && detail.specGroups.length > 0 && (
      <section class="wp-specs" aria-labelledby="specs-heading">
        <div class="wp-specs__header">
          <h2 id="specs-heading" class="wp-specs__title">Especificaciones Técnicas</h2>
          <div class="wp-specs__rule" aria-hidden="true"></div>
        </div>

        <div class="wp-specs__grid">
          {detail.specGroups.map((group) => (
            <div class="spec-card">
              <span class="material-symbols-outlined spec-card__icon" aria-hidden="true">{group.icon}</span>
              <h3 class="spec-card__title">{group.title}</h3>
              <ul class="spec-card__rows">
                {group.rows.map((row) => (
                  <li class="spec-row">
                    <span class="spec-row__label">{row.label}</span>
                    <span class="spec-row__value">{row.value}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- ── 3. ERGONOMICS / HOW IT LOOKS ON ── -->
    {detail?.ergonomics && (
      <section class="wp-ergo" aria-labelledby="ergo-heading">
        <div class="wp-ergo__image-wrap">
          {detail.ergonomics.image ? (
            <img
              src={detail.ergonomics.image.src}
              alt={detail.ergonomics.image.alt}
              class="wp-ergo__image"
              loading="lazy"
            />
          ) : (
            <div class="wp-ergo__image-placeholder" aria-hidden="true"></div>
          )}
          <div class="wp-ergo__overlay" aria-hidden="true"></div>
        </div>

        <div class="wp-ergo__content">
          <p class="wp-ergo__eyebrow">HOW IT LOOKS ON</p>
          <h2 id="ergo-heading" class="wp-ergo__title">{detail.ergonomics.title}</h2>
          <div class="wp-ergo__body">
            {detail.ergonomics.body.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
          <a href={watch.ctaUrl} target="_blank" rel="noopener noreferrer" class="wp-ergo__link">
            <span class="wp-ergo__link-line" aria-hidden="true"></span>
            Explora la ergonomía
          </a>
        </div>
      </section>
    )}

    <!-- ── FOOTER ── -->
    <footer class="wp-footer" aria-label="Pie de página">
      <span class="wp-footer__brand">AVC Time</span>
      <nav class="wp-footer__links" aria-label="Legal">
        <a href="#">Privacidad</a>
        <a href="#">Términos</a>
        <a href="#">Newsletter</a>
      </nav>
      <span class="wp-footer__copy">© 2024 AVC TIME. Todos los derechos reservados.</span>
    </footer>

  </div>
</Base>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@400,0&display=swap');

  /* ── Page shell ─────────────────────────────────────────────────────── */
  .watch-page {
    min-height: 100vh;
    background:
      linear-gradient(
        to top left,
        rgb(140 115 70 / 0.2) 0%,
        rgb(100 85 55 / 0.08) 35%,
        transparent 60%
      ),
      #0c0a08;
    color: var(--color-on-surface, #e5e2e1);
  }

  /* ── Navbar ──────────────────────────────────────────────────────────── */
  .wp-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2.5rem;
    background: rgb(12 10 8 / 0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgb(255 255 255 / 0.05);
  }

  .wp-nav__back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant, #a3a3a3);
    text-decoration: none;
    transition: color 200ms ease;
  }
  .wp-nav__back:hover { color: var(--color-primary, #f2ca50); }

  .wp-nav__brand {
    font-family: var(--font-display, 'Noto Serif', serif);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary, #f2ca50);
    text-decoration: none;
  }

  .wp-nav__spacer { width: 6rem; }

  /* ── Hero ────────────────────────────────────────────────────────────── */
  .wp-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 85vh;
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 2.5rem 5rem;
    gap: 3rem;
    align-items: center;
  }

  .wp-hero__content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .wp-eyebrow {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant, #a3a3a3);
    margin: 0;
  }

  .wp-title {
    font-family: var(--font-display, 'Noto Serif', serif);
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 700;
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--color-on-surface, #e5e2e1);
    margin: 0;
  }
  .wp-title__accent { color: var(--color-primary, #f2ca50); }

  .wp-collection {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant, #a3a3a3);
    margin: -0.5rem 0 0;
  }

  .wp-description {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 1rem;
    line-height: 1.75;
    color: rgb(229 226 225 / 0.75);
    max-width: 38ch;
    margin: 0;
  }

  /* CTA row */
  .wp-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-top: 0.5rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 1rem 1.75rem;
    background: var(--color-primary, #f2ca50);
    color: #241a00;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    border-radius: 2px;
    text-decoration: none;
    transition: background 200ms ease, box-shadow 200ms ease;
    box-shadow: 0 0 28px rgb(242 202 80 / 0.25);
  }
  .btn-primary:hover {
    background: #e9c349;
    box-shadow: 0 0 40px rgb(242 202 80 / 0.4);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 1rem 1.75rem;
    background: transparent;
    color: var(--color-on-surface, #e5e2e1);
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    border-radius: 2px;
    border: 1px solid rgb(255 255 255 / 0.15);
    text-decoration: none;
    transition: border-color 200ms ease, background 200ms ease;
  }
  .btn-secondary:hover {
    border-color: rgb(255 255 255 / 0.35);
    background: rgb(255 255 255 / 0.04);
  }

  /* Hero image */
  .wp-hero__image-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .wp-hero__glow {
    position: absolute;
    inset: 10%;
    border-radius: 50%;
    background: radial-gradient(circle, rgb(212 175 55 / 0.18) 0%, transparent 70%);
    pointer-events: none;
  }
  .wp-hero__image {
    width: 100%;
    max-width: 520px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 40px 80px rgb(0 0 0 / 0.7));
    animation: float 6s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-12px); }
  }

  /* ── Specs ───────────────────────────────────────────────────────────── */
  .wp-specs {
    max-width: 1280px;
    margin: 0 auto;
    padding: 5rem 2.5rem;
    border-top: 1px solid rgb(255 255 255 / 0.06);
  }

  .wp-specs__header {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .wp-specs__title {
    font-family: var(--font-display, 'Noto Serif', serif);
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--color-on-surface, #e5e2e1);
    white-space: nowrap;
    margin: 0;
  }

  .wp-specs__rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--color-primary, #f2ca50), transparent);
  }

  .wp-specs__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgb(255 255 255 / 0.06);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-radius: 4px;
    overflow: hidden;
  }

  .spec-card {
    background: rgb(255 255 255 / 0.02);
    padding: 2rem 1.5rem;
    transition: background 200ms ease;
  }
  .spec-card:hover { background: rgb(255 255 255 / 0.05); }

  .spec-card__icon {
    font-family: 'Material Symbols Outlined', sans-serif;
    font-size: 1.75rem;
    color: var(--color-primary, #f2ca50);
    display: block;
    margin-bottom: 1rem;
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
  }

  .spec-card__title {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-on-surface, #e5e2e1);
    margin: 0 0 1.25rem;
  }

  .spec-card__rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .spec-row {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid rgb(255 255 255 / 0.06);
  }
  .spec-row:last-child { border-bottom: none; padding-bottom: 0; }

  .spec-row__label {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant, #a3a3a3);
  }

  .spec-row__value {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-on-surface, #e5e2e1);
  }

  /* ── Ergonomics ──────────────────────────────────────────────────────── */
  .wp-ergo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
    border-top: 1px solid rgb(255 255 255 / 0.06);
  }

  .wp-ergo__image-wrap {
    position: relative;
    overflow: hidden;
  }
  .wp-ergo__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: grayscale(0.3);
  }
  .wp-ergo__image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a1a1a 0%, #0c0a08 100%);
  }
  .wp-ergo__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 50%, #0c0a08);
  }

  .wp-ergo__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 4rem;
    gap: 1.5rem;
    background: #0c0a08;
  }

  .wp-ergo__eyebrow {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-primary, #f2ca50);
    margin: 0;
  }

  .wp-ergo__title {
    font-family: var(--font-display, 'Noto Serif', serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-on-surface, #e5e2e1);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .wp-ergo__body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .wp-ergo__body p {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.9rem;
    line-height: 1.8;
    color: rgb(229 226 225 / 0.65);
    margin: 0;
    max-width: 42ch;
  }

  .wp-ergo__link {
    display: inline-flex;
    align-items: center;
    gap: 1.25rem;
    margin-top: 0.5rem;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-on-surface, #e5e2e1);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 200ms ease;
  }
  .wp-ergo__link:hover { color: var(--color-primary, #f2ca50); }
  .wp-ergo__link-line {
    display: inline-block;
    width: 3rem;
    height: 1px;
    background: var(--color-primary, #f2ca50);
    flex-shrink: 0;
    transition: width 200ms ease;
  }
  .wp-ergo__link:hover .wp-ergo__link-line { width: 4rem; }

  /* ── Footer ──────────────────────────────────────────────────────────── */
  .wp-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 2rem 2.5rem;
    border-top: 1px solid rgb(255 255 255 / 0.06);
  }

  .wp-footer__brand {
    font-family: var(--font-display, 'Noto Serif', serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary, #f2ca50);
  }

  .wp-footer__links {
    display: flex;
    gap: 1.5rem;
  }
  .wp-footer__links a {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant, #a3a3a3);
    text-decoration: none;
    transition: color 200ms ease;
  }
  .wp-footer__links a:hover { color: var(--color-on-surface, #e5e2e1); }

  .wp-footer__copy {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.68rem;
    color: rgb(255 255 255 / 0.25);
  }

  /* ── Responsive ──────────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .wp-hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding: 3rem 1.5rem 4rem;
    }
    .wp-hero__image-wrap { order: -1; }
    .wp-hero__image { max-width: 300px; margin: 0 auto; display: block; }

    .wp-specs { padding: 3rem 1.5rem; }
    .wp-specs__grid { grid-template-columns: repeat(2, 1fr); }

    .wp-ergo { grid-template-columns: 1fr; }
    .wp-ergo__image-wrap { height: 320px; }
    .wp-ergo__overlay { background: linear-gradient(to bottom, transparent 40%, #0c0a08); }
    .wp-ergo__content { padding: 3rem 1.5rem; }

    .wp-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }

  @media (max-width: 560px) {
    .wp-specs__grid { grid-template-columns: 1fr; }
    .wp-nav { padding: 1rem 1.25rem; }
    .wp-nav__spacer { display: none; }
  }
</style>
