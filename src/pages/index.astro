---
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Tooltip from '../components/ui/Tooltip.astro';
import Base from '../layouts/Base.astro';
---

<Base
  title="AVC TIME | Fundación visual"
  description="Base inicial del sistema visual para una experiencia de alta relojería sobria, editorial y precisa."
>
  <main class="page-shell landing-foundation">
    <section class="hero-copy">
      <p class="eyebrow">The Digital Curator</p>
      <h1>AVC TIME materializa una presencia sobria, técnica y silenciosamente lujosa.</h1>
      <p class="intro">
        Esta base valida tipografía, color, superficie y ritmo visual antes de construir la vitrina
        principal de la colección.
      </p>

      <div class="actions">
        <Button href="https://wa.me/5490000000000" variant="primary">
          Consultar con concierge
        </Button>
        <Button href="#foundation-card" variant="secondary">Ver materialidad</Button>
        <Tooltip text="Tooltip de referencia con glassmorphism y transición contenida." position="right">
          <Button variant="tertiary">Detalle curatorial</Button>
        </Tooltip>
      </div>
    </section>

    <Card>
      <div class="feature-card" id="foundation-card">
        <div>
          <p class="eyebrow">Editorial foundation</p>
          <h2>Capas tonales, serif con autoridad y acentos champagne.</h2>
        </div>

        <p>
          El sistema evita la estética de catálogo genérico: no hay líneas duras para separar,
          solo profundidad, contraste medido y aire suficiente para que cada pieza respire.
        </p>

        <ul class="spec-list">
          <li>
            <span>Tipografía</span>
            <strong>Noto Serif + Inter</strong>
          </li>
          <li>
            <span>Superficie</span>
            <strong>Obsidiana y metal cálido</strong>
          </li>
          <li>
            <span>Conversión</span>
            <strong>WhatsApp concierge</strong>
          </li>
        </ul>
      </div>
    </Card>
  </main>
</Base>

<style>
  .landing-foundation {
    display: grid;
    gap: var(--space-48);
    padding-block: var(--space-64);
  }

  .hero-copy {
    display: grid;
    gap: var(--space-24);
    padding-block: var(--space-48) var(--space-16);
  }

  .eyebrow {
    color: var(--color-on-surface-variant);
    font-size: var(--text-label-md);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-label);
    text-transform: uppercase;
  }

  h1,
  h2 {
    font-family: var(--font-display);
    font-weight: 600;
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-display);
  }

  h1 {
    max-width: 12ch;
    font-size: clamp(3rem, 6vw, var(--text-display-lg));
  }

  h2 {
    max-width: 18ch;
    font-size: clamp(2rem, 4vw, var(--text-headline-md));
  }

  .intro,
  .feature-card p {
    max-width: 60ch;
    color: var(--color-on-surface-variant);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-16);
    align-items: center;
  }

  .feature-card {
    display: grid;
    gap: var(--space-24);
  }

  .spec-list {
    display: grid;
    gap: var(--space-24);
  }

  .spec-list li {
    display: grid;
    gap: var(--space-4);
  }

  .spec-list span {
    color: var(--color-on-surface-variant);
    font-size: var(--text-label-md);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .spec-list strong {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 500;
  }

  @media (max-width: 720px) {
    .landing-foundation {
      padding-block: var(--space-48);
    }

    .actions {
      align-items: stretch;
    }
  }
</style>
