---
import Base from '../layouts/Base.astro';
import CatalogHeader from '../components/catalog/CatalogHeader.astro';
import CatalogCascade from '../components/catalog/CatalogCascade.astro';
import { watches } from '../data/watches';
---

<Base
  title="Catálogo | AVC TIME — Alta Relojería"
  description="Explora nuestra selección curada de relojes de alta relojería. Piezas icónicas disponibles para consulta privada."
>
  <div class="catalog-shell">
    <CatalogHeader />

    <main class="catalog-main">
      <!-- Hero editorial -->
      <section class="catalog-hero" aria-labelledby="catalog-heading">
        <div class="catalog-hero__content">
          <p class="catalog-hero__eyebrow">Curaduría Exclusiva</p>
          <h1 id="catalog-heading" class="catalog-hero__title">
            Obras Maestras<br />
            <span class="catalog-hero__title--dim">del Tiempo</span>
          </h1>
        </div>

      </section>

      <!-- Cascade grid -->
      <section class="catalog-grid-section" aria-label="Lista de relojes">
        <CatalogCascade watches={watches} />
      </section>
    </main>

    <!-- Footer minimal -->
    <footer class="catalog-footer" aria-label="Pie de página">
      <span class="catalog-footer__brand">AVC Time</span>
      <nav class="catalog-footer__links" aria-label="Legal">
        <a href="#">Privacidad</a>
        <a href="#">Términos</a>
        <a href="#">Newsletter</a>
      </nav>
      <span class="catalog-footer__copy">© 2024 AVC TIME. Todos los derechos reservados.</span>
    </footer>
  </div>
</Base>

<script>
  const FILTER_KEY = 'avc-catalog-filter';

  function initFilters() {
    const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
    const items = document.querySelectorAll<HTMLElement>('.cascade-item');
    const watchLinks = document.querySelectorAll<HTMLAnchorElement>('.cascade-item__link');

    if (pills.length === 0 || items.length === 0) return;

    function applyFilter(filter: string) {
      // Sync pill active state
      pills.forEach((p) => {
        p.classList.toggle('is-active', p.dataset.filter === filter);
      });

      items.forEach((item) => {
        const match = filter === 'all' || item.dataset.category === filter;
        if (match) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    }

    // Cuando el usuario hace clic en una píldora, guardar el filtro
    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const filter = pill.dataset.filter ?? 'all';
        sessionStorage.setItem(FILTER_KEY, filter);
        applyFilter(filter);
      });
    });

    // Cuando el usuario hace clic en un reloj, el filtro ya está guardado
    // No necesitamos hacer nada extra aquí, sessionStorage persiste la sesión

    // Al volver al catálogo, restaurar el último filtro activo
    const savedFilter = sessionStorage.getItem(FILTER_KEY) ?? 'all';
    applyFilter(savedFilter);
  }

  document.addEventListener('astro:page-load', initFilters);
</script>

<style>
  .catalog-shell {
    min-height: 100vh;
    min-height: 100dvh;
    display: grid;
    grid-template-rows: auto 1fr auto;
    background:
      linear-gradient(
        to top left,
        rgb(140 115 70 / 0.28) 0%,
        rgb(100 85 55 / 0.1) 35%,
        transparent 60%
      ),
      #0c0a08;
  }

  .catalog-main {
    width: min(1200px, calc(100% - var(--space-48)));
    margin: 0 auto;
    padding: 0;
  }

  /* ── Hero ── */
  .catalog-hero {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-32);
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .catalog-hero__eyebrow {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant);
    margin-bottom: var(--space-12);
  }

  .catalog-hero__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2rem);
    font-weight: 700;
    line-height: var(--line-height-tight);
    color: var(--color-on-surface);
    letter-spacing: var(--letter-spacing-display);
  }

  .catalog-hero__title--dim {
    color: var(--color-on-surface-variant);
  }

  /* ── Grid section ── */
  .catalog-grid-section {
    margin-top: 0;
  }

  /* ── Footer ── */
  .catalog-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-16);
    padding: var(--space-32) min(var(--space-48), 4vw);
    border-top: 1px solid rgb(var(--color-outline-variant-rgb) / 0.1);
  }

  .catalog-footer__brand {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: 0.04em;
  }

  .catalog-footer__links {
    display: flex;
    gap: var(--space-24);
  }

  .catalog-footer__links a {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-on-surface-variant);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color var(--transition-precision);
  }

  .catalog-footer__links a:hover {
    color: var(--color-on-surface);
  }

  .catalog-footer__copy {
    font-family: var(--font-body);
    font-size: 0.7rem;
    color: rgb(var(--color-outline-variant-rgb) / 0.6);
    letter-spacing: 0.04em;
  }

  @media (max-width: 720px) {
    .catalog-hero {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: var(--space-32);
    }

    .catalog-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-12);
    }
  }
</style>
